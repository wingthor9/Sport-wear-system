
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Employee {
  employee_id   String        @id @default(uuid())
  employee_name String
  gender        String?
  email         String        @unique
  phone         String
  address       String?
  position      String?
  password      String
  role          Role  @default(STAFF)
  failedLoginAttempts Int @default(0)
  lockUntil DateTime?


  isActive      Boolean       @default(true)
  lastLogin     DateTime?

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  purchases     PurchaseOrder[]
  imports       Import[]
  sales         Sale[]
  RefreshTokens RefreshToken[]



  @@index([email])
}

enum Role {
  ADMIN
  STAFF
  CUSTOMER
}

model RefreshToken {
  token_id String @id @default(uuid())
  token String @unique
  customer_id String?
  employee_id String?

  customer Customer? @relation(fields:[customer_id], references:[customer_id], onDelete: Cascade)
  employee Employee? @relation(fields:[employee_id], references:[employee_id], onDelete: Cascade)

  expiresAt DateTime
  createdAt DateTime @default(now())
}



model OTP {
  otp_id String @id @default(uuid())

  email String
  otp_code String
  type OTPType

  expiresAt DateTime
  verified Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([email])
}

enum OTPType {
  RESET_PASSWORD
  VERIFY_EMAIL
}



model Category {
  category_id   String      @id @default(uuid())
  category_name String
  description   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products      Product[]
}



model Product {
  product_id    String      @id @default(uuid())
  product_code  String      @unique
  product_name  String
  purchase_price  Int?
  sale_price    Int
  stock_qty     Int
  description   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category_id   String
  category      Category @relation(fields: [category_id], references: [category_id])

  images       ProductImage[]

  purchase_details PurchaseDetail[]
  import_details   ImportDetail[]
  order_details    OrderDetail[]
  sale_details     SaleDetail[]

  @@index([category_id])
}




model ProductImage {
  image_id   String   @id @default(uuid())
  image_url  String
  public_id  String

  product_id String
  product    Product @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

}




model Customer {
  customer_id   String   @id @default(uuid())
  customer_name String
  password      String
  phone         String   @unique
  email         String   @unique
  gender        String?
  address       String?
  role          Role @default(CUSTOMER)
  isActive      Boolean       @default(true)
  point         Int      @default(0)
  lastLogin     DateTime?

  failedLoginAttempts Int @default(0)
  lockUntil DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders        Order[]
  sales         Sale[]
  points        Point[]
  RefreshTokens RefreshToken[]
  
  @@index([email])
  @@index([phone])
}




model Supplier {
  supplier_id   String      @id @default(uuid())
  supplier_name String
  phone         String
  address       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchase_orders PurchaseOrder[]
}




model PurchaseOrder {
  purchase_id   String      @id @default(uuid())
  purchase_code String      @unique
  purchase_date DateTime @default(now())
  total_amount  Int?
  status        String   @default("pending")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  supplier_id   String
  employee_id   String

  supplier      Supplier @relation(fields: [supplier_id], references: [supplier_id])
  employee      Employee @relation(fields: [employee_id], references: [employee_id])

  purchase_details PurchaseDetail[]
  imports          Import[]

  @@index([supplier_id])
  @@index([employee_id])
}




model PurchaseDetail {
  purchase_detail_id String @id @default(uuid())
  quantity           Int
  price              Int
  received_qty       Int    @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchase_id String
  product_id  String

  purchase PurchaseOrder @relation(fields: [purchase_id], references: [purchase_id], onDelete: Cascade)
  product  Product       @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@index([purchase_id])
  @@index([product_id])

}

model Import {
  import_id   String      @id @default(uuid())
  import_code String      @unique
  import_date DateTime @default(now())
  purchase_id String
  employee_id String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchase PurchaseOrder @relation(fields: [purchase_id], references: [purchase_id])
  employee Employee      @relation(fields: [employee_id], references: [employee_id])

  import_details ImportDetail[]
}

model ImportDetail {
  import_detail_id String @id @default(uuid())
  quantity         Int
  cost_price       Int
  import_id String
  product_id String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  import  Import  @relation(fields: [import_id], references: [import_id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [product_id], onDelete: Cascade)

  @@index([import_id])
  @@index([product_id])
}

model Order {
  order_id     String      @id @default(uuid())
  order_code   String      @unique
  order_date   DateTime @default(now())
  status OrderStatus @default(WAITING_PAYMENT)
  total_amount Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer_id  String

  customer Customer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)

  order_details OrderDetail[]
  payment       Payment?
  delivery      Delivery?

  @@index([customer_id])
}


enum OrderStatus {
  WAITING_PAYMENT
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}


model OrderDetail {
  order_detail_id String @id @default(uuid())
  quantity        Int
  price           Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order_id  String
  product_id String

  order   Order   @relation(fields: [order_id], references: [order_id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [product_id])
}

model Sale {
  sale_id      String      @id @default(uuid())
  sale_date    DateTime @default(now())
  total_amount Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employee_id  String
  customer_id  String?

  employee Employee @relation(fields: [employee_id], references: [employee_id])
  customer Customer? @relation(fields: [customer_id], references: [customer_id])

  sale_details SaleDetail[]
  refund       Refund[]
}

model SaleDetail {
  sale_detail_id String @id @default(uuid())
  quantity       Int
  price          Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sale_id  String
  product_id String

  sale    Sale    @relation(fields: [sale_id], references: [sale_id], onDelete: Cascade)
  product Product @relation(fields: [product_id], references: [product_id])
}


model Refund {
  refund_id    String   @id @default(uuid())
  refund_code  String   @unique
  sale_id      String
  total_amount Int
  createdAt    DateTime @default(now())

  sale         Sale     @relation(fields: [sale_id], references: [sale_id])
  refund_details RefundDetail[]
}

model RefundDetail {
  refund_detail_id String @id @default(uuid())
  product_id       String
  quantity         Int
  price            Int

  refund_id String
  refund    Refund @relation(fields: [refund_id], references: [refund_id], onDelete: Cascade)
}

model Payment {
  payment_id   String      @id @default(uuid())
  payment_date DateTime    @default(now())
  amount       Int
  method       PaymentMethod @default(CASH)
  status       PaymentStatus @default(PENDING)
  slip_url     String?     // รูปสลิป (Cloudinary)
  public_id    String?     // ไว้ลบรูป
  verified_by  String?     // employee_id
  verified_at  DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  order_id String @unique
  order Order @relation(fields: [order_id], references: [order_id])
}

enum PaymentMethod {
  CASH
  TRANSFER
}


enum PaymentStatus {
  PENDING
  VERIFIED
  REJECTED
}

model Delivery {
  delivery_id String @id @default(uuid())
  status DeliveryStatus @default(PENDING)
  tracking_number String?
  provider String? @default("Anousith Express")
  order_id String @unique
  order Order @relation(fields: [order_id], references: [order_id])
  address_id String
  address AddressBranch @relation(fields: [address_id], references: [address_id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AddressBranch {
  address_id String @id @default(uuid())

  province_id String
  district_id String
  branch_id String

  province Province @relation(fields: [province_id], references: [province_id])
  district District @relation(fields: [district_id], references: [district_id])
  branch   Branch   @relation(fields: [branch_id], references: [branch_id])

  deliveries Delivery[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([province_id, district_id, branch_id]) 
}

model AddressBranch {
  address_id String @id @default(uuid())

  province_id String
  district_id String
  branch_id String

  province Province @relation(fields: [province_id], references: [province_id])
  district District @relation(fields: [district_id], references: [district_id])
  branch   Branch   @relation(fields: [branch_id], references: [branch_id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([province_id, district_id, branch_id]) // 🔥 กัน duplicate
}

model Province {
  province_id String @id @default(uuid())
  province_name String

  districts District[]
  addressBranches AddressBranch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model District {
  district_id String @id @default(uuid())
  district_name String

  province_id String
  province Province @relation(fields: [province_id], references: [province_id], onDelete: Cascade)

  branches Branch[]
  addressBranches AddressBranch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Branch {
  branch_id String @id @default(uuid())
  branch_name String

  district_id String
  district District @relation(fields: [district_id], references: [district_id], onDelete: Cascade)

  addressBranches AddressBranch[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum DeliveryStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model Point {
  point_id     String      @id @default(uuid())
  point_amount Int
  date         DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  customer_id String
  customer Customer @relation(fields: [customer_id], references: [customer_id], onDelete: Cascade)
}
